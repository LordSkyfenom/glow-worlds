<!DOCTYPE html>
<html>
<head>
    <title>Форум — Glow Worlds</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="/images/crystal.png">
    <style>
        .forum-box { max-width: 800px; margin: 30px auto; background: white; border-radius: 20px; padding: 20px; }
        .category-bar { display: flex; gap: 10px; margin-bottom: 20px; }
        .cat-btn { padding: 8px 20px; border: none; border-radius: 30px; cursor: pointer; background: #e0e0e0; font-weight: bold; }
        .cat-btn.active { background: #24af68; color: white; }
        .messages { height: 400px; overflow-y: auto; border: 1px solid #ddd; border-radius: 15px; padding: 15px; margin-bottom: 20px; background: #fafafa; }
        .msg { margin-bottom: 15px; padding: 10px; background: white; border-radius: 10px; }
        .msg strong { color: #24af68; }
        .msg small { color: #999; font-size: 11px; }
        .input-area { display: flex; gap: 10px; }
        .input-area input { flex: 1; padding: 12px; border: 1px solid #ccc; border-radius: 30px; }
        .input-area button { background: #24af68; color: white; border: none; padding: 12px 25px; border-radius: 30px; cursor: pointer; }
        .login-message { text-align: center; padding: 40px; background: #f9f9f9; border-radius: 20px; }
    </style>
</head>
<body>
    <header>
        <img src="/images/icon.png" class="logo">
        <h1>Glow Worlds</h1>
        <nav>
            <a href="/">Главная</a>
            <a href="/donate">Донат</a>
            <a href="/forum">Форум</a>
            <% if (user) { %>
                <div class="user-menu">
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="avatar">
                    <span><%= user.username %></span>
                    <a href="/logout">Выйти</a>
                </div>
            <% } else { %>
                <a href="/auth/discord">Войти через Discord</a>
            <% } %>
        </nav>
    </header>

    <div class="forum-box">
        <h2>Форум</h2>

        <% if (user) { %>
            <div class="category-bar">
                <button class="cat-btn active" data-cat="friends">👥 Друзья</button>
                <button class="cat-btn" data-cat="cities">🏠 Города</button>
                <button class="cat-btn" data-cat="news">📰 Новости</button>
            </div>

            <div id="messages" class="messages">
                Сообщения загружаются...
            </div>

            <div class="input-area">
                <input type="text" id="msgInput" placeholder="Напишите сообщение...">
                <button id="sendBtn">Отправить</button>
            </div>
        <% } else { %>
            <div class="login-message">
                <p>🔐 Войдите через Discord, чтобы участвовать в форуме.</p>
                <a href="/auth/discord">Войти</a>
            </div>
        <% } %>
    </div>

    <script>
        let currentCat = 'friends';
        const user = <%- JSON.stringify(user || null) %>;

        async function load() {
            const container = document.getElementById('messages');
            if (!container) return;
            container.innerHTML = '⏳ Загрузка...';
            try {
                const res = await fetch(`/api/messages?category=${currentCat}`);
                const data = await res.json();
                if (!Array.isArray(data)) throw new Error('Не массив');
                
                if (data.length === 0) {
                    container.innerHTML = '<div style="text-align:center;color:#999;">Нет сообщений. Напишите первым!</div>';
                    return;
                }
                
                container.innerHTML = data.map(m => `
                    <div class="msg">
                        <strong>${escapeHtml(m.username)}</strong> <small>${new Date(m.created_at).toLocaleString()}</small><br>
                        ${escapeHtml(m.message)}
                        ${user && m.discord_id === user.id ? `<br><button onclick="del(${m.id})">🗑️ Удалить</button>` : ''}
                    </div>
                `).join('');
                container.scrollTop = container.scrollHeight;
            } catch(e) {
                console.error(e);
                container.innerHTML = '<div style="color:red;">Ошибка загрузки</div>';
            }
        }

        async function del(id) {
            if (!confirm('Удалить?')) return;
            await fetch(`/api/messages/${id}`, { method: 'DELETE' });
            load();
        }

        async function send() {
            const input = document.getElementById('msgInput');
            const text = input.value.trim();
            if (!text) return;
            input.value = '';
            const btn = document.getElementById('sendBtn');
            btn.disabled = true;
            try {
                await fetch('/api/messages', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ category: currentCat, message: text })
                });
                load();
            } catch(e) {
                alert('Ошибка отправки');
            }
            btn.disabled = false;
        }

        function escapeHtml(str) {
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        document.getElementById('sendBtn')?.addEventListener('click', send);
        document.getElementById('msgInput')?.addEventListener('keypress', e => { if (e.key === 'Enter') send(); });

        document.querySelectorAll('.cat-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentCat = btn.dataset.cat;
                load();
            });
        });

        load();
        setInterval(load, 5000);
    </script>
</body>
</html>