<script>
    let currentOrderId = null;
    let currentPrice = 0;

    async function createOrder(product, nick) {
        const res = await fetch('/create-order', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ product, minecraft_nick: nick })
        });
        const data = await res.json();
        if (data.orderId) {
            currentOrderId = data.orderId;
            currentPrice = data.price;
            // Открываем ЮMoney в новой вкладке
            window.open(data.paymentUrl, '_blank');
            // Показываем модальное окно с кнопкой "Я оплатил"
            showPaymentModal();
        } else {
            alert('Ошибка: ' + (data.error || 'Неизвестная ошибка'));
        }
    }

    function showPaymentModal() {
        const modal = document.createElement('div');
        modal.className = 'modal';
        modal.innerHTML = `
            <div class="modal-content">
                <h3>💳 Оплата через ЮMoney</h3>
                <p>Сумма: <strong>${currentPrice} ₽</strong></p>
                <p>Если вы оплатили, нажмите кнопку ниже</p>
                <button id="confirmPaymentBtn">✅ Я оплатил</button>
                <button onclick="this.closest('.modal').remove()">❌ Отмена</button>
            </div>
        `;
        document.body.appendChild(modal);
        modal.style.display = 'flex';
        
        document.getElementById('confirmPaymentBtn').addEventListener('click', async () => {
            const res = await fetch('/api/mark-as-paid', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ orderId: currentOrderId })
            });
            const data = await res.json();
            if (data.success) {
                alert('✅ Спасибо! Администратор проверит оплату.');
                modal.remove();
                location.reload();
            } else {
                alert('❌ Ошибка: ' + data.error);
            }
        });
    }

    // Вызов при нажатии "Купить"
    document.querySelectorAll('.buy-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            if (!<%= !!user %>) {
                alert('Сначала войдите через Discord');
                return;
            }
            const product = btn.closest('.donate-card').dataset.product;
            const nick = prompt('Введите Minecraft ник');
            if (!nick) return;
            await createOrder(product, nick);
        });
    });
</script>