<!DOCTYPE html>
<html>
<head>
    <title>Glow Worlds</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="/images/crystal.png">
</head>
<body>
    <header>
        <img src="/images/icon.png" class="logo">
        <h1>Glow Worlds</h1>
        <nav>
            <a href="/">Главная</a>
            <a href="/donate">Донат</a>
            <a href="/forum">Форум</a>
            <a href="/profile">Профиль</a>
            <% if (user) { %>
                <div class="user-menu">
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="avatar">
                    <span><%= user.username %></span>
                    <a href="/logout">Выйти</a>
                </div>
            <% } else { %>
                <a href="/auth/discord" class="login-btn">Войти через Discord</a>
            <% } %>
        </nav>
    </header>

    <img src="/images/home.png" alt="Banner" class="banner">

    <div class="servers-container" style="display: flex; justify-content: center; gap: 40px; flex-wrap: wrap; margin: 40px auto; max-width: 1200px;">
        <% servers.forEach(server => { %>
            <div class="server-card" style="background: white; border-radius: 20px; padding: 30px; text-align: center; width: 280px; box-shadow: 0 5px 20px rgba(0,0,0,0.1);">
                <img src="<%= server.icon_url %>" alt="<%= server.name %>" style="width: 80px; margin-bottom: 15px;">
                <h2 style="color: #24af68;"><%= server.name %></h2>
                <p><%= server.version %></p>
                <div class="online">🟢 Онлайн: <span class="online-count" data-server-id="<%= server.id %>">0</span> / 20</div>
                <button onclick="copyIP('<%= server.ip %>')">📋 Копировать IP</button>
            </div>
        <% }); %>
    </div>

    <script>
        function copyIP(ip) {
            navigator.clipboard.writeText(ip);
            alert('IP скопирован: ' + ip);
        }
        
        async function updateOnline() {
            try {
                const res = await fetch('/api/online');
                const data = await res.json();
                document.querySelectorAll('.online-count').forEach(el => {
                    const serverId = el.dataset.serverId;
                    el.textContent = data[serverId] || 0;
                });
            } catch(e) { console.error('Ошибка обновления онлайна'); }
        }
        
        updateOnline();
        setInterval(updateOnline, 30000);
    </script>
</body>
</html>