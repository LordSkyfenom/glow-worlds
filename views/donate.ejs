<!DOCTYPE html>
<html>
<head>
    <title>Донат — Glow Worlds</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="/images/crystal.png">
    <style>
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); justify-content: center; align-items: center; z-index: 1000; }
        .modal-content { background: white; padding: 30px; border-radius: 20px; text-align: center; min-width: 300px; }
        .modal-content input { width: 100%; padding: 10px; margin: 15px 0; border-radius: 10px; border: 1px solid #ccc; }
    </style>
</head>
<body>
    <header>
        <img src="/images/icon.png" class="logo">
        <h1>Glow Worlds</h1>
        <nav>
            <a href="/">Главная</a>
            <a href="/donate">Донат</a>
            <a href="/forum">Форум</a>
            <a href="/profile">Профиль</a>
            <% if (user) { %>
                <div class="user-menu">
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="avatar">
                    <span><%= user.username %></span>
                    <a href="/logout">Выйти</a>
                </div>
            <% } else { %>
                <a href="/auth/discord" class="login-btn">Войти через Discord</a>
            <% } %>
        </nav>
    </header>

    <div class="donate-container">
        <% products.forEach(product => { %>
            <div class="donate-card" data-product-id="<%= product.id %>">
                <img src="<%= product.image_url %>" alt="<%= product.name %>">
                <h3><%= product.name %></h3>
                <p><%= product.description %></p>
                <span class="price"><%= product.price %> ₽</span>
                <button class="buy-btn">Купить</button>
            </div>
        <% }); %>
    </div>

    <div id="nickModal" class="modal">
        <div class="modal-content">
            <h3>Введите Minecraft ник</h3>
            <input type="text" id="minecraftNick" placeholder="Ваш ник">
            <button id="submitNick">Подтвердить</button>
            <button onclick="closeNickModal()">Отмена</button>
        </div>
    </div>

    <script>
        let selectedProductId = null;
        let currentOrderId = null;
        let currentPrice = 0;
        let currentPaymentUrl = '';

        document.querySelectorAll('.buy-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                if (!<%= !!user %>) {
                    alert('Сначала войдите через Discord');
                    window.location.href = '/auth/discord';
                    return;
                }
                selectedProductId = btn.closest('.donate-card').dataset.productId;
                document.getElementById('nickModal').style.display = 'flex';
            });
        });

        document.getElementById('submitNick').addEventListener('click', async () => {
            const nick = document.getElementById('minecraftNick').value.trim();
            if (!nick) { alert('Введите Minecraft ник'); return; }
            closeNickModal();
            
            const res = await fetch('/create-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: selectedProductId, minecraft_nick: nick })
            });
            const data = await res.json();
            if (data.orderId) {
                currentOrderId = data.orderId;
                currentPrice = data.price;
                currentPaymentUrl = data.paymentUrl;
                window.open(currentPaymentUrl, '_blank');
                showPaymentModal();
            } else {
                alert('Ошибка: ' + (data.error || 'Неизвестная ошибка'));
            }
        });

        function showPaymentModal() {
            const modal = document.createElement('div');
            modal.className = 'modal';
            modal.innerHTML = `
                <div class="modal-content">
                    <h3>💳 Оплата через ЮMoney</h3>
                    <p>Сумма: <strong>${currentPrice} ₽</strong></p>
                    <p>После оплаты нажмите кнопку ниже</p>
                    <button id="confirmPaymentBtn">✅ Я оплатил</button>
                    <button onclick="this.closest('.modal').remove()">❌ Отмена</button>
                </div>
            `;
            document.body.appendChild(modal);
            modal.style.display = 'flex';
            document.getElementById('confirmPaymentBtn').addEventListener('click', async () => {
                const res = await fetch('/api/mark-as-paid', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId: currentOrderId })
                });
                const data = await res.json();
                if (data.success) {
                    alert('✅ Спасибо! Администратор проверит оплату.');
                    modal.remove();
                    location.reload();
                } else {
                    alert('❌ Ошибка: ' + (data.error || 'Попробуйте позже'));
                }
            });
        }

        function closeNickModal() {
            document.getElementById('nickModal').style.display = 'none';
            document.getElementById('minecraftNick').value = '';
        }
    </script>
</body>
</html>