<!DOCTYPE html>
<html>
<head><title>Профиль</title><link rel="stylesheet" href="/css/style.css"></head>
<body>
    <header>
        <img src="/images/icon.png" class="logo"><h1>Glow Worlds</h1>
        <nav><a href="/">Главная</a><a href="/donate">Донат</a><a href="/forum">Форум</a><a href="/profile">Профиль</a>
        <% if (user && user.isOwner) { %><a href="/admin-panel" class="login-btn">👑 Админка</a><% } %>
        <% if (user) { %>
            <div class="user-menu"><img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="avatar"><span><%= user.username %></span><a href="/logout">Выйти</a></div>
        <% } else { %><a href="/auth/discord" class="login-btn">Войти через Discord</a><% } %>
        </nav>
    </header>
    <div class="profile-page" style="max-width:1000px;margin:40px auto;background:white;border-radius:20px;padding:20px">
        <h2>Мои заказы</h2>
        <% if (orders.length === 0) { %><p>Нет заказов</p>
        <% } else { orders.forEach(order => { %>
            <div style="border:1px solid #ddd;border-radius:10px;padding:15px;margin:10px 0">
                <strong>#<%= order.id %></strong> | <%= order.product_type %> | <%= order.price %>₽ | Статус: <%= order.status %><br>
                Minecraft ник: <%= order.minecraft_nick %><br>
                Дата: <%= new Date(order.created_at).toLocaleString() %>
                <% if (order.status === 'confirmed' || order.status === 'cancelled') { %>
                    <br><button onclick="deleteOrder(<%= order.id %>)">🗑️ Удалить заказ</button>
                <% } %>
            </div>
        <% }) } %>
        <a href="/logout" style="display:inline-block;margin-top:20px;background:#ff5555;color:white;padding:10px 20px;border-radius:10px">Выйти</a>
    </div>
    <script>
        async function deleteOrder(id) {
            if (!confirm('Удалить заказ?')) return;
            const res = await fetch(`/api/delete-order/${id}`, { method: 'DELETE' });
            if (res.ok) location.reload();
            else alert('Ошибка удаления');
        }
    </script>
</body>
</html>